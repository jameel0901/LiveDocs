# Copy to .env for local development. On Render/hosting, set these in the dashboard.
# Never commit .env to git.

NODE_ENV=development
PORT=5000

# MongoDB connection string (required)
ATLAS_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# Auth (required) — use a long random string (32+ chars in production)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d

# Frontend origin allowed to call the API (required in production, no wildcards)
# Local:
CORS_ORIGIN=http://localhost:3000
# Production example:
# CORS_ORIGIN=https://your-username.github.io

# Admin accounts (comma-separated emails promoted to admin on login)
ADMIN_EMAILS=admin@example.com

# Optional: seed/sync admin password on server startup (use only for local/dev)
# In production set ADMIN_SEED_ON_STARTUP=true only if you intentionally want this.
ADMIN_SEED_ON_STARTUP=false
ADMIN_PASSWORD=
